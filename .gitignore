# Python
__pycache__/
*.py[cod]
*.so

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# 权重不上传
sr/save/
sr/*.pth

# sr/res：忽略图片等大文件，只保留日志与 FIRE 误差明细
sr/res/**/*
!sr/res/**/
!sr/res/**/*.log
!sr/res/**/FIRE_point_errors.txt

# sr/FIRE_results：同样只保留误差文本（约 136KB）
sr/FIRE_results/**/*
!sr/FIRE_results/**/
!sr/FIRE_results/**/FIRE_point_errors.txt

# Temporary files
*.tmp
*.swp
